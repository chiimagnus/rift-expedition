{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "baseUrl": "./src",
    "paths": {
      "@ui/*": ["ui/*"],
      "@viewmodels/*": ["viewmodels/*"],
      "@services/*": ["services/*"],
      "@models/*": ["models/*"]
    }
  },
  "include": ["src"]
}
