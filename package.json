{
  "name": "rift-expedition",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsc --noEmit",
    "build": "esbuild src/entrypoints/main.ts --bundle --format=iife --global-name=RiftExpedition --target=es2022 --sourcemap --outfile=dist/main.js",
    "test:build": "node scripts/build-tests.mjs",
    "test": "npm run test:build && node --test dist-tests/*.test.js",
    "smoke": "node scripts/smoke.mjs",
    "gate": "npm run compile && npm test && npm run build && npm run smoke",
    "dev": "esbuild src/entrypoints/main.ts --bundle --format=iife --global-name=RiftExpedition --target=es2022 --sourcemap --outfile=dist/main.js --servedir=."
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
