[
  {
    "id": "elder_intro",
    "speakerName": "村长顾怀恩",
    "lines": [
      "昨夜新娘沈砚在婚宴前失踪，旧矿洞方向传来兽叫。",
      "先去村外查脚印，再沿野路找线索。"
    ]
  },
  {
    "id": "fiance_accuse",
    "speakerName": "未婚夫梁铮",
    "lines": [
      "外来法师问过矿洞的路，沈砚随后失踪。",
      "村长一直拦着大家进矿洞，他肯定知道什么。"
    ]
  },
  {
    "id": "guard_gate",
    "speakerName": "守卫阿砾",
    "lines": [
      "东门通往村外，河岸也能绕去野外。"
    ]
  },
  {
    "id": "notice_board",
    "speakerName": "旧公告板",
    "lines": [
      "旧矿洞封闭，任何人不得私采元素矿。",
      "若见沈砚或外来女法师，立刻报告村长。"
    ]
  },
  {
    "id": "healer_request",
    "speakerName": "药师林婆",
    "lines": [
      "村里三个孩子开始发毒热，普通草药压不住。",
      "若你们去野外河湾，替我采一束苦根草回来。"
    ]
  },
  {
    "id": "healer_return",
    "speakerName": "药师林婆",
    "lines": [
      "把苦根草给我，这些止血药剂你们带走。"
    ]
  },
  {
    "id": "bridge_warning",
    "speakerName": "河桥木牌",
    "lines": [
      "过桥去野外河湾，别在夜里回头。",
      "桥下水面浮着彩色油膜。"
    ]
  },
  {
    "id": "elder_return",
    "speakerName": "村长顾怀恩",
    "lines": [
      "把线索交给我，这笔血债才算有了开头。"
    ]
  }
]
