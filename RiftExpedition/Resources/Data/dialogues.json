[
  {
    "id": "elder_intro",
    "speakerName": "村长顾怀恩",
    "lines": [
      "昨夜新娘沈砚在婚宴前失踪，旧矿洞方向传来兽叫。",
      "先去村外查脚印，再沿野路找线索。"
    ]
  },
  {
    "id": "fiance_accuse",
    "speakerName": "未婚夫梁铮",
    "lines": [
      "外来法师问过矿洞的路，沈砚随后失踪。",
      "村长一直拦着大家进矿洞，他肯定知道什么。"
    ]
  },
  {
    "id": "guard_gate",
    "speakerName": "守卫阿砾",
    "lines": [
      "东门通往村外，河岸也能绕去野外。"
    ]
  },
  {
    "id": "notice_board",
    "speakerName": "旧公告板",
    "lines": [
      "旧矿洞封闭，任何人不得私采元素矿。",
      "若见沈砚或外来女法师，立刻报告村长。"
    ]
  },
  {
    "id": "healer_request",
    "speakerName": "药师林婆",
    "lines": [
      "村里三个孩子开始发毒热，普通草药压不住。",
      "若你们去野外河湾，替我采一束苦根草回来。"
    ]
  },
  {
    "id": "healer_return",
    "speakerName": "药师林婆",
    "lines": [
      "把苦根草给我，这些止血药剂和河誓坠饰你们带走。"
    ]
  },
  {
    "id": "bridge_warning",
    "speakerName": "河桥木牌",
    "lines": [
      "过桥去野外河湾，别在夜里回头。",
      "桥下水面浮着彩色油膜。"
    ]
  },
  {
    "id": "cave_entrance_trace",
    "speakerName": "洞口痕迹",
    "lines": [
      "碎石旁压着一枚刻着“砚”字的银发簪。",
      "血迹一路往矿道深处拖去，旁边有细小幼兽爪印。"
    ]
  },
  {
    "id": "mine_evidence",
    "speakerName": "元素矿账册",
    "lines": [
      "账册私印属于村长，封矿后仍有人把元素矿运出村。",
      "污染不是天灾，而是长期偷采挖穿了封层。"
    ]
  },
  {
    "id": "daughter_reveal",
    "speakerName": "沈砚",
    "lines": [
      "我不是被外来法师掳走，是在保护裂隙幼体。",
      "村长偷采元素矿挖穿封层，毒雾才冲进河里。"
    ]
  },
  {
    "id": "chapter_end_marker",
    "speakerName": "裂隙洞心",
    "lines": [
      "暗卫倒下，幼体退回石缝。",
      "你们已经拿到足够证据，可以回村揭穿村长。"
    ]
  },
  {
    "id": "elder_return",
    "speakerName": "村长顾怀恩",
    "lines": [
      "账册上的私印指向村长顾怀恩，梁铮的指控当场崩塌。",
      "沈砚证明污染来自偷采元素矿，村长被守卫押走。"
    ]
  }
]
